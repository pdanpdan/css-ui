{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "singleQuote": true,
  "ignorePatterns": [],
  "sortTailwindcss": {
    "stylesheet": "./packages/playground/assets/main.css",
    "preserveWhitespace": true
  },
  "sortImports": {
    "groups": [
      "type-import",
      [
        "value-builtin",
        "value-external"
      ],
      "type-internal",
      "value-internal",
      [
        "type-parent",
        "type-sibling",
        "type-index"
      ],
      [
        "value-parent",
        "value-sibling",
        "value-index"
      ],
      "unknown"
    ]
  },
  "sortPackageJson": {
    "sortScripts": true
  }
}
