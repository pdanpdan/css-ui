{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "jsPlugins": [
    "@stylistic/eslint-plugin"
  ],
  "plugins": [
    "oxc",
    "typescript",
    "vue"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn",
    "style": "warn",
    "restriction": "warn"
  },
  "env": {
    "browser": true,
    "es6": true,
    "vue": true
  },
  "rules": {
    "no-undef": "error",
    "max-statements": "off",
    "no-ternary": "off",
    "no-magic-numbers": "off",
    "func-style": [
      "error",
      "declaration",
      {
        "allowArrowFunctions": true
      }
    ],
    "no-duplicate-imports": [
      "error",
      {
        "allowSeparateTypeImports": true,
        "includeExports": true
      }
    ],
    "sort-imports": [
      "error",
      {
        "allowSeparatedGroups": true,
        "ignoreDeclarationSort": true,
      }
    ],
    "oxc/no-optional-chaining": "off",
    "@stylistic/semi": [
      "error",
      "always"
    ],
    "@stylistic/comma-dangle": [
      "error",
      "always-multiline"
    ],
    "@stylistic/indent": [
      "error",
      2
    ],
    "@stylistic/max-statements-per-line": [
      "error",
      {
        "max": 1
      }
    ]
  }
}
