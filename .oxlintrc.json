{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "jsPlugins": [
    "@stylistic/eslint-plugin"
  ],
  "plugins": [
    "oxc",
    "typescript",
    "vue"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn",
    "style": "warn",
    "restriction": "warn"
  },
  "env": {
    "browser": true,
    "es6": true,
    "vue": true
  },
  "rules": {
    "no-undef": "error",
    "max-statements": "off",
    "no-ternary": "off",
    "no-magic-numbers": "off",
    "no-async-await": "off",
    "no-rest-spread-properties": "off",
    "no-eq-null": "off",
    "complexity": "off",
    "prefer-destructuring": [
      "error",
      {
        "array": false,
        "object": true,
      }
    ],
    "no-console": [
      "error",
      {
        "allow": [
          "log",
          "info",
          "warn"
        ]
      }
    ],
    "id-length": [
      "error",
      {
        "exceptions": [
          "x",
          "y",
          "i",
          "j",
          "a",
          "b",
          "v",
          "o"
        ]
      }
    ],
    "func-style": [
      "error",
      "declaration",
      {
        "allowArrowFunctions": true
      }
    ],
    "no-duplicate-imports": [
      "error",
      {
        "allowSeparateTypeImports": true,
        "includeExports": true
      }
    ],
    "sort-keys": "off",
    "sort-imports": [
      "error",
      {
        "allowSeparatedGroups": true,
        "ignoreDeclarationSort": true,
      }
    ],
    "oxc/no-optional-chaining": "off",
    "@stylistic/semi": [
      "error",
      "always"
    ],
    "@stylistic/comma-dangle": [
      "error",
      "always-multiline"
    ],
    "@stylistic/indent": [
      "error",
      2
    ],
    "@stylistic/max-statements-per-line": [
      "error",
      {
        "max": 1
      }
    ]
  }
}
